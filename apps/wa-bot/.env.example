# =============================================================================
#  Versifine — WhatsApp bot environment template
#  This file documents every variable the bot reads. The bot loads from the
#  repo-root .env via `--env-file=../../.env`; copy keys into that file.
# =============================================================================

# --- Bot ↔ API trust boundary -------------------------------------------------
# The bot signs every server-to-server call with this header so the API can
# trust phone identity claims. MUST match BOT_SECRET in the API env.
BOT_SECRET=change-me-to-a-shared-secret

# --- API target ---------------------------------------------------------------
# Where the API is reachable from the bot's process. Default localhost:5000.
API_URL=http://localhost:5000

# --- Internal HTTP server -----------------------------------------------------
# Hosts /health, /qr, /qr.png, /send, /broadcast/*, /simulator/*.
BOT_PORT=5001
BOT_HOST=127.0.0.1

# --- Identity & session -------------------------------------------------------
BOT_NAME=Versifine
SESSION_ID=VERSIFINE_DEV
# When true, only numbers in ALLOWED_TEST_NUMBERS get a reply. Use during demos.
DEMO_MODE=true
# Comma-separated digit-only phone numbers, e.g. 919876543210,919812345678
ALLOWED_TEST_NUMBERS=
# Run Chromium without a visible window. Set to false to watch what's happening.
HEADLESS=true

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_AUDIO_MODEL=gpt-4o-audio-preview
OPENAI_AUDIO_VOICE=shimmer
OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# --- TTS behaviour ------------------------------------------------------------
TTS_ENABLED=true
TTS_MAX_CHARS=600

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
