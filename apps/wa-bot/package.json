{
  "name": "@versifine/wa-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "dev:supervised": "bun --env-file=../../.env src/supervisor.ts",
    "typecheck": "tsc --noEmit",
    "lint:phrases": "bun run scripts/lint-banned-phrases.mjs",
    "start": "bun src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@versifine/shared": "workspace:*",
    "hono": "4.6.16",
    "openai": "4.77.0",
    "qrcode": "1.5.4",
    "qrcode-terminal": "0.12.0",
    "whatsapp-web.js": "1.34.7",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.0",
    "@types/qrcode": "1.5.5",
    "typescript": "5.7.3"
  }
}
