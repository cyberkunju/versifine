# =============================================================================
#  Versifine — environment template
#  Copy to .env at repo root. Each app may also have its own .env that
#  overrides what's here.
# =============================================================================

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgres://versifine:versifine@localhost:5432/versifine_dev
DATABASE_URL_TEST=postgres://versifine:versifine@localhost:5432/versifine_test

# --- API server ---------------------------------------------------------------
API_PORT=5000
API_HOST=127.0.0.1
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000
NODE_ENV=development
LOG_LEVEL=info

# --- Bot ↔ API trust boundary -------------------------------------------------
# Both api and wa-bot read this. The bot signs every internal request to the
# API with this header so the API can trust phone identity claims.
BOT_SECRET=change-me-to-a-shared-secret

# --- WhatsApp bot -------------------------------------------------------------
BOT_PORT=5001
BOT_HOST=127.0.0.1
BOT_NAME=Versifine
SESSION_ID=VERSIFINE_DEV
DEMO_MODE=true
ALLOWED_TEST_NUMBERS=
HEADLESS=true

# --- Web ----------------------------------------------------------------------
WEB_PORT=5173
PUBLIC_API_URL=http://localhost:5000
PUBLIC_WS_URL=ws://localhost:5000/ws
PUBLIC_GOOGLE_CLIENT_ID=

# --- Google Sign-In ------------------------------------------------------------
# Create a Web OAuth client in Google Cloud Console and use the same client ID
# in PUBLIC_GOOGLE_CLIENT_ID (web) and GOOGLE_CLIENT_ID (api).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_ALLOWED_DOMAINS=

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_VISION_MODEL=gpt-4o
OPENAI_PARSE_MODEL=gpt-5-mini
OPENAI_NLU_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_AUDIO_MODEL=gpt-4o-audio-preview
OPENAI_AUDIO_VOICE=shimmer

# --- TTS behaviour ------------------------------------------------------------
TTS_ENABLED=true
TTS_MAX_CHARS=600

# --- Foreign exchange ---------------------------------------------------------
FX_API_URL=https://open.er-api.com/v6/latest
FX_CACHE_SECONDS=21600

# --- WhatsApp Business Cloud API (Meta Graph) --------------------------------
# When WHATSAPP_TOKEN is set, the bot runs on the official Cloud API (no Chromium)
# and the API's /webhook/whatsapp receives Meta events. Leave blank to keep the
# whatsapp-web.js path (used for local testing).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Must match the token you enter in the Meta dashboard webhook config.
WHATSAPP_VERIFY_TOKEN=
# Meta App Secret — used to HMAC-verify every inbound webhook. REQUIRED in prod.
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v23.0
# Where the API relays parsed inbound messages to the bot (internal).
WABOT_INTERNAL_URL=http://127.0.0.1:5001
