# Versifine API — production environment file.
# Goes on the server at /etc/versifine/api.env (mode 0640, root:versifine).
# Generated locally then `scp`'d once. Never committed to git.

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgres://versifine:versifine_local@127.0.0.1:5432/versifine_dev

# --- API server ---------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=5100
NODE_ENV=production
LOG_LEVEL=info

# --- JWT secrets (generate fresh, 32+ random chars each) ---------------------
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-hex-32
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# --- Bot ↔ API trust boundary -------------------------------------------------
BOT_SECRET=replace-me-with-a-long-shared-secret

# --- Google Sign-In ------------------------------------------------------------
# Same Web OAuth client ID compiled into the frontend.
GOOGLE_CLIENT_ID=
# Optional comma-separated extra client IDs during migrations.
GOOGLE_CLIENT_IDS=
# Optional comma-separated domain allowlist, e.g. example.com,company.com
GOOGLE_ALLOWED_DOMAINS=

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_VISION_MODEL=gpt-4o
OPENAI_PARSE_MODEL=gpt-5-mini
OPENAI_NLU_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_AUDIO_MODEL=gpt-4o-audio-preview
OPENAI_AUDIO_VOICE=shimmer

TTS_ENABLED=true
TTS_MAX_CHARS=600

FX_API_URL=https://open.er-api.com/v6/latest
FX_CACHE_SECONDS=21600

# --- WhatsApp Business Cloud API (Meta Graph) --------------------------------
# Production: set all four to run on the official Cloud API. The public webhook
# is GET/POST https://versifine.com/webhook/whatsapp (proxied to the API).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v23.0
WABOT_INTERNAL_URL=http://127.0.0.1:5001
