# Versifine WhatsApp Bot — production environment file.
# Goes on the server at /etc/versifine/wabot.env (mode 0640, root:versifine).

NODE_ENV=production
LOG_LEVEL=info

# Must match the API's BOT_SECRET so the bot can authenticate to the API.
BOT_SECRET=replace-me-with-the-same-shared-secret-as-api

# Internal URL the bot uses to talk to the API.
API_URL=http://127.0.0.1:5100

# Bot HTTP server (proxied at /wa-qr by nginx).
BOT_PORT=5101
BOT_HOST=127.0.0.1
BOT_NAME=Versifine
SESSION_ID=VERSIFINE_PROD

# Allowlist for private deployments. Empty = accept any number that's
# linked via /auth/phone-link/confirm.
DEMO_MODE=false
ALLOWED_TEST_NUMBERS=

# whatsapp-web.js requires a system Chromium (PUPPETEER_EXECUTABLE_PATH is
# set by the systemd unit; HEADLESS=true is mandatory in production).
HEADLESS=true

# --- Azure AI Foundry (LLM: ta/te/kn translation) ----------------------------
AZURE_AI_ENDPOINT=https://aip-f-resource.services.ai.azure.com
AZURE_AI_KEY=
AZURE_AI_API_VERSION=2024-05-01-preview
OPENAI_TRANSLATE_MODEL=gpt-5.4-nano
# Deprecated no-op (no direct OpenAI). Leave blank.
OPENAI_API_KEY=

# --- Speech (Azure + Sarvam only, no OpenAI/fallback) ------------------------
# English STT → Azure AI Speech (MAI-Transcribe-1.5).
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
# Indic STT → Sarvam Saaras; TTS (all langs) → Sarvam Bulbul.
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=kabir

TTS_ENABLED=true
TTS_MAX_CHARS=600

# --- WhatsApp Business Cloud API (Meta Graph) --------------------------------
# Set WHATSAPP_TOKEN + WHATSAPP_PHONE_NUMBER_ID to run on the Cloud API
# (the bot skips Chromium entirely and sends/receives via the Graph API).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0
