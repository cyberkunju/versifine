# Versifine Web (SvelteKit adapter-node) — production environment file.
# Goes on the server at /etc/versifine/web.env (mode 0640, root:versifine).

# adapter-node listens on HOST:PORT.
HOST=127.0.0.1
PORT=3100
NODE_ENV=production

# Public origin used by SvelteKit for absolute URLs (cookies, redirects).
ORIGIN=https://versifine.com

# Public env vars baked into the client bundle by Vite at build time.
#
# Leave PUBLIC_API_URL and PUBLIC_WS_URL UNSET in production. The web is
# same-origin behind nginx (which proxies /api/* → API and /ws → API WS), and
# the client automatically adds the /api prefix and derives wss://<host>/ws
# only when these are empty. Setting them to the bare origin
# (https://versifine.com) makes the client skip /api → auth POSTs hit the
# SvelteKit 404 page → "Response was not JSON". Only set PUBLIC_API_URL for a
# cross-origin setup where the web talks to the API host directly.
PUBLIC_GOOGLE_CLIENT_ID=
